# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bigotti_online_store?schema=public"

# Generate with: openssl rand -base64 64
JWT_SECRET="replace-with-a-long-random-secret-of-at-least-64-characters"

NODE_ENV="development"
PORT="3000"
TRUST_PROXY_HOPS="0"

FRONTEND_URL="http://localhost:3001"
PUBLIC_FRONTEND_URL="http://localhost:3001"
PUBLIC_API_URL="http://localhost:3000"

COOKIE_DOMAIN=""
COOKIE_SAME_SITE="lax"

GLOBAL_RATE_LIMIT_TTL_MS="60000"
GLOBAL_RATE_LIMIT_MAX="120"

APP_NAME="Bigotti Collection"

RESEND_API_KEY="re_your_api_key"
MAIL_FROM="Bigotti Collection <no-reply@your-domain.tld>"
MAIL_SUPPORT_EMAIL="support@your-domain.tld"
PASSWORD_RESET_DEBUG="false"

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Media storage
# Local development: local
# Azure production: azure
STORAGE_DRIVER="local"

# Development/Azurite only. Never use a Storage account key in production.
AZURE_STORAGE_CONNECTION_STRING=""

# Required with STORAGE_DRIVER=azure when no development connection string is used.
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_CONTAINER_NAME="media"

# Optional custom CDN/Front Door base URL including the container path.
# Example: https://media.your-domain.tld
AZURE_STORAGE_PUBLIC_BASE_URL=""

# Recommended locally with Azurite. Keep false in production and provision the
# container through Azure infrastructure/portal.
AZURE_STORAGE_AUTO_CREATE_CONTAINER="true"

# For this dedicated public catalog-media container only.
# "blob" public access exposes files but does not allow anonymous container listing.
AZURE_STORAGE_CONTAINER_PUBLIC="true"

# Optional for a user-assigned managed identity. Leave empty for a
# system-assigned managed identity.
AZURE_CLIENT_ID=""
