DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bigotti_online_store?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"

NODE_ENV="development"
PORT="3000"

FRONTEND_URL="http://localhost:3001,http://localhost:3000"
PUBLIC_FRONTEND_URL="http://localhost:3001"

APP_NAME="Bigotti Collection"
RESEND_API_KEY="re_your_api_key"
MAIL_FROM="Bigotti Collection <no-reply@example.com>"
MAIL_SUPPORT_EMAIL="support@example.com"

# Development only. Never enable in production.
PASSWORD_RESET_DEBUG="false"

# Configure later for Google Sign-In.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
